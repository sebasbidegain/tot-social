# Server
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=tot_app
DB_PASS=your_password_here
DB_NAME=tot_db

# JWT (generate RSA keys: openssl genrsa 2048 | base64 -w0)
JWT_PRIVATE_KEY=base64_encoded_private_key
JWT_PUBLIC_KEY=base64_encoded_public_key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_DAYS=30

# Uploads
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100

# Frontend URL (for email links)
FRONTEND_URL=https://tot-social.com

# SMTP (email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@tot-social.com
SMTP_PASS=your_email_password_here
SMTP_FROM=ToT Social <no-reply@tot-social.com>

# Web Push (VAPID keys: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:no-reply@tot-social.com
